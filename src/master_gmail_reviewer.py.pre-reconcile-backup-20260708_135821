def sniff_media_type_from_bytes(data: bytes):
    """[ADDED 2026-07-03] Returns the real media type based on the file's actual
    magic-byte signature, not its filename extension — see the call site in
    analyze_attachments_with_claude() for the live bug this fixes. Only covers
    the 4 formats this pipeline actually sends to Claude's API (jpeg/png/tiff/
    pdf); returns None (not a guess) for anything else, including corrupt or
    truncated data, so the caller can fall back to the extension-based guess
    rather than this function inventing an answer it isn't sure of."""
    if not data:
        return None
    if data[:3] == b"\xff\xd8\xff":
        return "image/jpeg"
    if data[:8] == b"\x89PNG\r\n\x1a\n":
        return "image/png"
    if data[:4] in (b"II*\x00", b"MM\x00*"):
        return "image/tiff"
    if data[:5] == b"%PDF-":
        return "application/pdf"
    return None


