def get_plain_text_body(message: dict) -> str:
    """[v1.1] Extracts the plain-text body of a message for the general-inquiry
    flow. Falls back to the Gmail-provided snippet if no text/plain part is found
    (e.g. HTML-only emails)."""
    def walk(payload):
        mime = payload.get("mimeType", "")
        body = payload.get("body", {})
        if mime == "text/plain" and body.get("data"):
            try:
                return base64.urlsafe_b64decode(body["data"] + "==").decode("utf-8", errors="replace")
            except Exception:
                return ""
        for part in payload.get("parts", []):
            result = walk(part)
            if result:
                return result
        return ""

    text = walk(message.get("payload", {}))
    if text.strip():
        return text.strip()
    return message.get("snippet", "").strip()


def build_thread_history_text(messages: list, exclude_id: str = None) -> str:
    """[v1.1] Formats a sender's prior emails (excluding the newest trigger
    message, which is passed separately as the 'new inbound email') into a
    readable block for Claude — same spirit as upgrade1's Gmail preview
    formatting, but with full body text since this is the primary channel
    for the general-inquiry decision, not a secondary context signal."""
    lines = []
    sorted_msgs = sorted(messages, key=lambda m: int(m.get("internalDate", 0)))
    for msg in sorted_msgs:
        if exclude_id and msg["id"] == exclude_id:
            continue
        date_str = extract_header(msg, "Date")
        from_str = extract_header(msg, "From")
        subj_str = extract_header(msg, "Subject")
        body = get_plain_text_body(msg)[:800]
        lines.append(f"[{date_str}] FROM: {from_str} | SUBJECT: {subj_str}\n{body}")
    return "\n\n".join(lines)


def extract_header(message: dict, header_name: str) -> str:
    headers = message.get("payload", {}).get("headers", [])
    for h in headers:
        if h.get("name", "").lower() == header_name.lower():
            return h.get("value", "")
    return ""


def extract_email_address(from_header: str) -> str:
    match = re.search(r'<([^>]+)>', from_header)
    if match:
        return match.group(1).lower().strip()
    return from_header.lower().strip()


def get_parts(payload: dict) -> list:
    parts = []
    if payload.get("filename"):
        parts.append(payload)
    for part in payload.get("parts", []):
        parts.extend(get_parts(part))
    return parts


MAX_DOCS_PER_SENDER = 10  # Prevents 413 Payload Too Large on Anthropic API

def get_all_attachments(service, messages: list) -> list:
    attachments = []
    for message in messages:
        if len(attachments) >= MAX_DOCS_PER_SENDER:
            log.warning(f"  Doc cap of {MAX_DOCS_PER_SENDER} reached — skipping remaining")
            break
        parts = get_parts(message.get("payload", {}))
        for part in parts:
            if len(attachments) >= MAX_DOCS_PER_SENDER:
                break
            filename = part.get("filename", "")
            mime_type = part.get("mimeType", "")
            body = part.get("body", {})
            if not filename:
                continue
            ext = Path(filename).suffix.lower()
            if ext not in {".pdf", ".jpg", ".jpeg", ".png", ".docx", ".doc", ".tiff", ".tif"}:
                continue
            att_id = body.get("attachmentId")
            data_b64 = body.get("data")
            if att_id:
                att = service.users().messages().attachments().get(
                    userId="me", messageId=message["id"], id=att_id
                ).execute()
                data_b64 = att.get("data", "")
            if data_b64:
                data = base64.urlsafe_b64decode(data_b64 + "==")
                attachments.append({
                    "filename": filename,
                    "data": data,
                    "mime_type": mime_type,
                    "message_id": message["id"],
                })
    return attachments


def mark_as_read(service, message_id: str):
    service.users().messages().modify(
