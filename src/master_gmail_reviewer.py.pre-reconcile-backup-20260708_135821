def load_center_email_domains() -> set:
    """Returns the set of email domains found anywhere in
    BLUELINE_CENTER_DIRECTORY.md, so known center/facility senders are never
    treated as candidates. Returns an empty set (fails open, not closed) if
    the file doesn't exist — an unreachable directory should degrade to "no
    extra exclusions," never to accidentally blocking real candidates."""
    global _center_domain_cache
    if _center_domain_cache is not None:
        return _center_domain_cache
    if not CENTER_DIRECTORY_PATH.exists():
        log.warning(f"Center directory not found at {CENTER_DIRECTORY_PATH} — "
                    f"center-domain email exclusion is a no-op until it exists")
        _center_domain_cache = set()
        return _center_domain_cache
    text = CENTER_DIRECTORY_PATH.read_text(encoding="utf-8", errors="replace")
    emails = re.findall(r"[\w.+-]+@[\w-]+\.[\w.-]+", text)
    _center_domain_cache = {e.split("@")[-1].lower() for e in emails}
    return _center_domain_cache


def is_system_or_non_candidate_email(email: str) -> bool:
    """Returns True if this email should be skipped (not a candidate)."""
    email = email.lower().strip()
    # [FIXED 2026-07-03] The agency's own address was never explicitly excluded here. As long as
    # get_unread_messages_all() required is:unread, this never surfaced — Gmail auto-marks an
    # account's own Sent copies as read, so BLUELINE_EMAIL never matched is:unread and this gap
    # was invisible. The moment is:unread was dropped (same-day fix, to catch already-read
    # candidate emails), Sent-mail messages from info@bluelinestaffing.com started coming back
    # too (the query has no in:inbox restriction), and one got processed as if BlueLine's own
    # address were "the candidate" (confirmed live: a doc draft got saved for
    # info@bluelinestaffing.com with license: None). Excluding by sender here (not by adding
    # -in:sent to the query) is deliberate — a single thread can mix an agency-sent message with a
    # real candidate reply, and filtering by sender still lets the candidate's own message in that
    # same thread through.
    if email == BLUELINE_EMAIL.lower():
        return True
    if email in BLOCKED_FULL_EMAILS:
        return True
    domain = email.split("@")[-1] if "@" in email else ""
    if domain in BLOCKED_EMAIL_DOMAINS:
        return True
    # [ADDED 2026-07-03] Known center/facility domains — see comment above.
    if domain in load_center_email_domains():
        return True
    prefix = email.split("@")[0] if "@" in email else email
    if any(prefix.startswith(p) for p in BLOCKED_EMAIL_PREFIXES):
        return True
    return False


